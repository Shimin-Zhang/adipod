---
import BaseLayout from './BaseLayout.astro';

interface FAQ {
  question: string;
  answer: string;
}

interface Props {
  title: string;
  description: string;
  date?: string;
  keywords?: string;
  lastUpdated?: string;
  faqs?: FAQ[];
}

const { title, description, date, keywords, lastUpdated, faqs } = Astro.props;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description: description,
  datePublished: date || lastUpdated || undefined,
  dateModified: lastUpdated || date || undefined,
  author: [
    {
      '@type': 'Person',
      name: 'Shimin Zhang',
      jobTitle: 'Software Engineer',
      url: 'https://adipod.ai/about/shimin/',
    },
    {
      '@type': 'Person',
      name: 'Dan Lasky',
      jobTitle: 'Software Engineer',
      url: 'https://adipod.ai/about/dan/',
    },
    {
      '@type': 'Person',
      name: 'Rahul Yadav',
      jobTitle: 'Director of Engineering',
      url: 'https://adipod.ai/about/rahul/',
    },
  ],
  publisher: {
    '@type': 'Organization',
    name: 'ADI Pod',
    url: 'https://adipod.ai',
  },
};

const schemas: Record<string, unknown>[] = [articleSchema];

if (faqs && faqs.length > 0) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: faq.answer,
      },
    })),
  });
}
---

<BaseLayout title={title} description={description} schema={schemas} ogType="article">
  <article style="padding: 2rem 0;">
    <header>
      {date && <p class="meta">{new Date(date + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}{lastUpdated ? ` · Updated ${new Date(lastUpdated + 'T00:00:00').toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}` : ''}</p>}
      <h1>{title}</h1>
      {keywords && <p class="keywords">{keywords}</p>}
    </header>
    <slot />
  </article>
</BaseLayout>

<style>
  .meta { color: var(--color-text-muted); font-size: 0.9rem; margin-bottom: 0.25rem; }
  h1 { margin-top: 0.25rem; }
  .keywords { color: var(--color-text-muted); font-size: 0.85rem; font-style: italic; }
</style>
