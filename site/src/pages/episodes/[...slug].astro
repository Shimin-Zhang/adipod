---
import { getCollection, render } from 'astro:content';
import EpisodeLayout from '../../layouts/EpisodeLayout.astro';

export async function getStaticPaths() {
  const episodes = await getCollection('episodes');
  return episodes.map((ep) => ({
    params: { slug: ep.data.slug },
    props: { entry: ep },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<EpisodeLayout
  episode={entry.data.episode}
  title={entry.data.title}
  date={entry.data.date}
  description={entry.data.description}
  keywords={entry.data.keywords}
  appleUrl={entry.data.appleUrl}
  spotifyUrl={entry.data.spotifyUrl}
  overcastUrl={entry.data.overcastUrl}
  pocketCastsUrl={entry.data.pocketCastsUrl}
  amazonUrl={entry.data.amazonUrl}
  transistorId={entry.data.transistorId}
  youtubeId={entry.data.youtubeId}
>
  <Content />
</EpisodeLayout>
