---
const currentPath = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/episodes/', label: 'Episodes' },
  { href: '/blog/', label: 'Blog' },
  { href: '/topics/', label: 'Topics' },
  { href: '/glossary/', label: 'Glossary' },
  { href: '/about/', label: 'About' },
];
---

<nav>
  <a href="/" class="nav-brand">ADI Pod</a>
  <div class="nav-right">
    <div class="nav-links">
      {links.map(({ href, label }) => (
        <a href={href} class:list={[{ active: (currentPath.startsWith(href) && href !== '/') || currentPath === href }]}>
          {label}
        </a>
      ))}
    </div>
    <button id="theme-toggle" type="button" aria-label="Toggle dark mode" title="Toggle dark mode">
      <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
      <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
    </button>
    <button id="menu-toggle" type="button" aria-label="Toggle menu" title="Toggle menu">
      <svg class="icon-menu" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      <svg class="icon-close" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
</nav>

<style>
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    border-bottom: 1px solid var(--color-border);
    max-width: 1200px;
    margin: 0 auto;
  }
  .nav-brand {
    font-weight: 700;
    font-size: 1.25rem;
    text-decoration: none;
    color: var(--color-nav-brand);
    white-space: nowrap;
  }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }
  .nav-links {
    display: flex;
    gap: 1.5rem;
  }
  .nav-links a {
    text-decoration: none;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }
  .nav-links a:hover, .nav-links a.active {
    color: var(--color-nav-brand);
  }
  #theme-toggle, #menu-toggle {
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    padding: 0.35rem;
    cursor: pointer;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, border-color 0.15s;
  }
  #theme-toggle:hover, #menu-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-border-strong);
  }
  #menu-toggle {
    display: none;
  }
  .icon-close {
    display: none;
  }
  /* In light mode: show moon (click to go dark). In dark mode: show sun (click to go light). */
  .icon-sun { display: none; }
  .icon-moon { display: block; }
  :global([data-theme="dark"]) .icon-sun { display: block; }
  :global([data-theme="dark"]) .icon-moon { display: none; }
  @media (prefers-color-scheme: dark) {
    .icon-sun { display: block; }
    .icon-moon { display: none; }
    :global([data-theme="light"]) .icon-sun { display: none; }
    :global([data-theme="light"]) .icon-moon { display: block; }
  }

  @media (max-width: 640px) {
    nav {
      padding: 0.75rem 1rem;
    }
    #menu-toggle {
      display: flex;
    }
    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--color-bg, #fff);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 1.5rem;
      gap: 0.75rem;
      z-index: 100;
    }
    .nav-links a {
      font-size: 1rem;
    }
    nav {
      position: relative;
    }
    :global(.menu-open) .nav-links {
      display: flex;
    }
    :global(.menu-open) .icon-menu {
      display: none;
    }
    :global(.menu-open) .icon-close {
      display: block;
    }
  }
</style>

<script is:inline>
(function() {
  var btn = document.getElementById('menu-toggle');
  if (!btn) return;
  btn.addEventListener('click', function() {
    document.querySelector('nav').classList.toggle('menu-open');
  });
})();
</script>
